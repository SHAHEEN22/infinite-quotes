# Brave Search API
# Get yours at https://api.search.brave.com/
BRAVE_API_KEY=your_brave_api_key_here

# Anthropic (Claude)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vercel KV
# Automatically set when you add a KV store via the Vercel dashboard
# (Storage → Create → KV → connect to this project)
KV_REST_API_URL=your_kv_url_here
KV_REST_API_TOKEN=your_kv_token_here

# Cron job protection
# Set any random secret; Vercel passes this automatically for cron invocations
# https://vercel.com/docs/cron-jobs/manage-cron-jobs#securing-cron-jobs
CRON_SECRET=your_random_secret_here
