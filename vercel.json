{
  "rewrites": [
    { "source": "/", "destination": "/api/index" },
    { "source": "/admin", "destination": "/api/admin" },
    { "source": "/day/:path", "destination": "/api/day?date=:path" }
  ],
  "crons": [
    {
      "path": "/api/generate",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/threads",
      "schedule": "0 14 * * *"
    }
  ]
}
